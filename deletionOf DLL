class Node{
    int data;
    Node next;
    Node back;
    
    Node(int data1, Node next1, Node back1){
        this.data = data1;
        this.next = next1;
        this.back = back1;
    }
    
    Node(int data1, Node next1){
        this.data = data1;
        this.next = next1;
        this.back = null;
    }
    
    Node(int data1){
        this.data = data1;
        this.next = null;
        this.back = null;
    }
}

class Main {
    public static Node convertArrIntoDLL(int[] arr){
        Node head = new Node(arr[0]);
        Node prev = head;
        for(int i=1; i<arr.length; i++){
            Node temp = new Node(arr[i]);
            prev.next = temp;
            temp.back = prev;
            prev = temp;
        }
        return head;
    }
    
    //deletion of linked list 
    public static Node deleteHead(Node head){
        if(head == null || head.next == null) return null;
        
        Node prev = head;
        head = prev.next;
        head.back = null;
        prev.next = null;
        
        return head;
        }
        
    public static Node deleteTail(Node head){
        if(head == null || head.next == null) return null;
        Node tail = head;
        while(tail.next != null){
            tail = tail.next;
        }
        Node newTail = tail.back;
        newTail.next = null;
        tail.back = null; 
        
        return head;
    }
    
    public static Node deleteKthElement(Node head, Integer k){
        Node temp = head;
        Integer count = 1;
        while(temp.next != null){
           
            if(count == k){
                break;
            }
            temp = temp.next;
            count++;
        }
        
        Node prev = temp.back;
        Node front = temp.next;
        
        //edge cases 
        //if both prev and front are null
        if(prev == null && front == null){
            return null;
        }
        else if(prev == null)// if prev is null then it is head
        {
            return deleteHead(head);
        }
        else if(front == null){
            return deleteTail(head);
        }
        else{
            prev.next = temp.next;
            front.back = temp.back;
            
            temp.next = null;
            temp.back = null;
            
            return head;
        }
    }
    public static Node deleteNodeElement(Node head, int val){
        Node temp = head;
        while(temp != null){
            if(temp.data == val){
                break;
            }
            temp = temp.next;
        }
        Node prev = temp.back;
        Node front = temp.next;
        
        if(prev== null && front == null){
            return null;
        }
        else if(prev == null){
            return deleteHead(head);
        }
        else if(front == null){
            return deleteTail(head);
        }
        else {
            prev.next = temp.next;
            front.back = temp.back;
            
            temp.next = null;
            temp.back = null;
            
            return head;
        }
    }
    public static void traverseDLL(Node head){
        Node temp = head;
        while(temp != null){
            System.out.println(temp.data);
            temp = temp.next;
        }
    }
    
    public static void main(String[] args) {
        int[] array = new int[]{1,2,3,43,34};
        Node result =convertArrIntoDLL(array);
        System.out.println("--------TRAVERSE -------");
        traverseDLL(result);
        System.out.println("--------DELETE HEAD-------");
        Node result1 = deleteHead(result);
        traverseDLL(result1);
        System.out.println("--------DELETE TAIL-------");
        Node deletionTail_HEAD = deleteTail(result1);
        traverseDLL(deletionTail_HEAD);
        System.out.println("-------delete kth eleement -------");
        Node deletionKthElement_HEAD=deleteKthElement(deletionTail_HEAD,3);
        traverseDLL(deletionKthElement_HEAD);
        
        System.out.println("----------delete node element -------");
        Node deletionOfNodeelement = deleteNodeElement(deletionKthElement_HEAD,3);
        traverseDLL(deletionOfNodeelement);
        
        }
}
