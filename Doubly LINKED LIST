class Node{
    int data;
    Node next;
    Node back;
    
    Node(int data1, Node next1, Node back1){
        this.data = data1;
        this.next = next1;
        this.back = back1;
    }
    
    Node(int data1, Node next1){
        this.data = data1;
        this.next = next1;
        this.back = null;
    }
    
    Node(int data1){
        this.data = data1;
        this.next = null;
        this.back = null;
    }
}

class Main {
    public static Node convertArrIntoDLL(int[] arr){
        Node head = new Node(arr[0]);
        Node prev = head;
        for(int i=1; i<arr.length; i++){
            Node temp = new Node(arr[i]);
            prev.next = temp;
            prev = temp;
        }
        
        return head;
    }
    
    public static void traverseDLL(Node head){
        Node temp = head;
        while(temp.next != null){
            System.out.println(temp.data);
            temp = temp.next;
        }
    }
    
    public static void main(String[] args) {
        int[] array = new int[]{1,2,3,43,34};
        Node result =convertArrIntoDLL(array);
        System.out.println(result.data);
        traverseDLL(result);
    }
}
